# =========================================================
#  GA PERFORMANCE DASHBOARD - Environment Variables
# =========================================================
# Copy file ini menjadi .env dan isi nilai-nilai di bawah ini
#
# Cara mendapatkannya:
# - Firebase: https://console.firebase.google.com → Project Settings → General → Your apps
# - GAS URL: Deploy Code.gs sebagai Web App di Google Apps Script

# =========================================================
# FIREBASE AUTHENTICATION
# =========================================================
# Diperlukan untuk login manual (email+password) dan Google SSO.
# Firebase Authentication gratis hingga 10.000 user aktif/bulan.

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxx

# =========================================================
# GOOGLE APPS SCRIPT (GAS) BACKEND
# =========================================================
# URL Web App setelah deploy Code.gs di Google Apps Script.
# Jika tidak diisi, data akan menggunakan Mock Data (mode demo).
# Cara deploy: Extensions → Apps Script → Deploy → New Deployment → Web App

VITE_GAS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_GAS_SCRIPT_ID/exec
